{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/heroes/[id]",
      "regex": "^/heroes/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/heroes/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/knowledge/[slug]",
      "regex": "^/knowledge/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/knowledge/(?<nxtPslug>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/alliance",
      "regex": "^/alliance(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/alliance(?:/)?$"
    },
    {
      "page": "/analytics",
      "regex": "^/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/analytics(?:/)?$"
    },
    {
      "page": "/assistant",
      "regex": "^/assistant(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/assistant(?:/)?$"
    },
    {
      "page": "/buildings",
      "regex": "^/buildings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/buildings(?:/)?$"
    },
    {
      "page": "/events",
      "regex": "^/events(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/events(?:/)?$"
    },
    {
      "page": "/heroes",
      "regex": "^/heroes(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/heroes(?:/)?$"
    },
    {
      "page": "/items",
      "regex": "^/items(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/items(?:/)?$"
    },
    {
      "page": "/knowledge",
      "regex": "^/knowledge(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/knowledge(?:/)?$"
    },
    {
      "page": "/pets",
      "regex": "^/pets(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pets(?:/)?$"
    },
    {
      "page": "/research",
      "regex": "^/research(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/research(?:/)?$"
    },
    {
      "page": "/resources",
      "regex": "^/resources(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/resources(?:/)?$"
    },
    {
      "page": "/settings",
      "regex": "^/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings(?:/)?$"
    },
    {
      "page": "/state",
      "regex": "^/state(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/state(?:/)?$"
    },
    {
      "page": "/troops",
      "regex": "^/troops(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/troops(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}